# HarvestERP Next.js app — environment variables
# Copy this file to .env.local and fill in values for local development.

# FastAPI backend URL (no trailing slash)
HARVESTERP_API_URL=http://localhost:8000

# Set to "true" in production to mark the session cookie as Secure (HTTPS-only)
HARVESTERP_COOKIE_SECURE=false

# Cookie domain — set to your domain in production (e.g. .harvesterp.com)
HARVESTERP_COOKIE_DOMAIN=localhost
