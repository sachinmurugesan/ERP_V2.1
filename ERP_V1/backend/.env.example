# HarvestERP — Backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL is required. SQLite is not supported.
# Docker Compose (connecting via Docker DNS):
#   DATABASE_URL=postgresql://erp:erp_secure_password@db:5432/harvestdb
# Local uvicorn (connecting to exposed container port):
#   DATABASE_URL=postgresql://erp:erp_secure_password@localhost:5432/harvestdb
DATABASE_URL=postgresql://erp:erp_secure_password@localhost:5432/harvestdb

# ── AI / Claude API ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-with-a-strong-random-string-min-32-chars

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
ALLOW_DEV_AUTH=false
