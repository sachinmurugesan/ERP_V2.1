# ============================================
# HarvestERP — Environment Configuration
# Copy to .env and fill in production values
# ============================================

# ---- Database ----
# SQLite (development):
# DATABASE_URL=sqlite:///harvesterpdata.db
# PostgreSQL (production):
DATABASE_URL=postgresql://erp:YOUR_SECURE_PASSWORD@localhost:5432/harvestdb
DB_PASSWORD=YOUR_SECURE_PASSWORD
DB_PORT=5432

# ---- Security ----
# CRITICAL: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- AI / Claude API ----
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ---- File Uploads ----
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE=629145600
MAX_IMAGE_DIMENSION=4096
IMAGE_QUALITY=95

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ---- Server ----
PORT=8000
WORKERS=4
WORKER_TIMEOUT=60
MAX_REQUESTS=1000
LOG_LEVEL=info
DEBUG=false

# ---- Docker Compose Ports ----
API_PORT=8000
FRONTEND_PORT=3000
